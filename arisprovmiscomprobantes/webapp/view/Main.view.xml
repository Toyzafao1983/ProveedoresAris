<mvc:View controllerName="arisprovmiscomprobantes.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:f="sap.f"
    xmlns:core="sap.ui.core"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:u="sap.ui.unified"
    xmlns="sap.m">

        <f:DynamicPage headerExpanded="true" showFooter="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title level="H1"
                            text="{i18n>title}"
                            wrapping="true" />
                    </f:heading>
                    <f:actions>
                        <Button text="{i18n>textHome}" press="_onbtnHome" type="Back" icon="sap-icon://home"
                            tooltip="{i18n>tooltipbtnHome}" />
                        <MenuButton text="{i18n>titleButtonLanguaje}" icon="sap-icon://action-settings">
                            <menu>
                                <Menu itemSelected="onMenuAction">
                                    <MenuItem text="{i18n>titleButtonLanguajeEN}" press="onLanguageEng"
                                        icon="sap-icon://globe" />
                                    <MenuItem text="{i18n>titleButtonLanguajeES}" press="onLanguageEsp"
                                        icon="sap-icon://flag" />
                                </Menu>
                            </menu>
                        </MenuButton>
                    </f:actions>
                </f:DynamicPageTitle>
            </f:title>

            <f:header>
                <f:DynamicPageHeader>
                    <f:content>
                        <fb:FilterBar id="idFilterBar" filterContainerWidth="15rem"
                            reset="onReset"
                            search="_onPressExecute"
                            showFilterConfiguration="true"
                            showRestoreButton="false"
                            showClearOnFB="true"
                            showGoOnFB="true"
                            clear="onClearFilters"
                            useToolbar="false">

                            <fb:filterItems>

                                <!-- UNIDAD DE NEGOCIO (OBLIGATORIO) -->
                                <fb:FilterItem
                                    name="A"
                                    label="{i18n>filtros.unidadNegocio}"
                                    mandatory="true">
                                    <fb:control>
                                        <MultiComboBox
                                            id="mcbUnidadNegocio"
                                            width="100%"
                                            items="{
                                                path: 'oModelProyect>/oUnidadNegocio'
                                            }"
                                            selectionFinish=".onUnidadNegocioSelectionFinish"
                                            selectedKeys="{oModelProyect>/Main/filter/fUnidadNegocio}">
                                            <core:Item
                                                key="{oModelProyect>EMPRESA}"
                                                text="{oModelProyect>EMPRESA} - {oModelProyect>DESCRIPCION}" />
                                        </MultiComboBox>
                                    </fb:control>
                                </fb:FilterItem>

                                <!-- PROVEEDOR (OBLIGATORIO) -->
                                <fb:FilterItem
                                        name="B"
                                        label="{i18n>filtros.proveedor}"
                                        mandatory="{= !${oModelUser>/bEsExterno} }"
                                        visible="{= !${oModelUser>/bEsExterno} }"
                                        visibleInFilterBar="{= !${oModelUser>/bEsExterno} }">
                                    <fb:control>
                                        <MultiInput
                                            id="miProveedor"
                                            width="100%"
                                            enabled="{= !${oModelUser>/bEsExterno} }"
                                            showValueHelp="{= !${oModelUser>/bEsExterno} }"
                                            placeholder="{i18n>filtros.proveedor.placeholder}"
                                            showSuggestion="true"
                                            valueHelpRequest=".onValueHelpProveedor"
                                            suggestionItems="{
                                                path: 'oModelProyect>/oFacturaProveedor'
                                            }"
                                            suggestionItemSelected=".onProveedorSuggestionItemSelected"
                                            tokenUpdate=".onProveedorTokenUpdate">

                                            <core:Item
                                                key="{oModelProyect>SupplierCode}"
                                                text="{
                                                    parts: [
                                                        'oModelProyect>RUC',
                                                        'oModelProyect>SupplierName'
                                                    ],
                                                    formatter: '.formatProveedorTexto'
                                                }" />
                                        </MultiInput>
                                    </fb:control>
                                </fb:FilterItem>

                               <!-- CÓDIGO SAP -->
                                <fb:FilterItem
                                    name="C"
                                    label="{i18n>filtros.codSap}"
                                    visible="{= !${oModelUser>/bEsExterno} }"
                                    visibleInFilterBar="{= !${oModelUser>/bEsExterno} }">
                                    <fb:control>
                                        <MultiInput
                                            id="miCodProveedor"
                                            width="100%"
                                            enabled="{= !${oModelUser>/bEsExterno} }"
                                            showValueHelp="{= !${oModelUser>/bEsExterno} }"
                                            placeholder="{i18n>filtros.codSap.placeholder}"
                                            showSuggestion="true"
                                            valueHelpRequest=".onValueHelpCodSap"
                                            suggestionItems="{
                                                path: 'oModelProyect>/oFacturaProveedor'
                                            }"
                                            suggestionItemSelected=".onCodSapSuggestionItemSelected"
                                            tokenUpdate=".onCodSapTokenUpdate">

                                            <core:Item
                                                key="{oModelProyect>SupplierCode}"
                                                text="{
                                                    parts: [
                                                        'oModelProyect>SupplierCode',
                                                        'oModelProyect>SupplierName'
                                                    ],
                                                    formatter: '.formatProveedorTexto'
                                                }" />
                                        </MultiInput>
                                    </fb:control>
                                </fb:FilterItem>

                                <!-- ESTADO (OBLIGATORIO) -->
                                <fb:FilterItem
                                    name="E"
                                    label="{i18n>fiEsta}"
                                    mandatory="true">
                                    <fb:control>
                                        <ComboBox
                                            id="cbEstado"
                                            width="100%"
                                            selectedKey="{oModelProyect>/Main/filter/fEstado}"
                                            selectionChange=".onChangeEstado">
                                            <core:Item key="PAGADO" text="{i18n>fiEstaPag}" />
                                            <core:Item key="PENDIENTE" text="{i18n>fiEstaPen}" />
                                        </ComboBox>
                                    </fb:control>
                                </fb:FilterItem>

                                <!-- FECHA SI ESTADO ES PAGADO (OBLIGATORIO CUANDO ESTÁ VISIBLE) -->
                                <fb:FilterItem
                                        id="fiFechaPagado"
                                        name="F"
                                        label="{i18n>txtFechCompro}">
                                        <fb:control>
                                            <DateRangeSelection
                                                id="dprFilterInitPagado"
                                                width="250px"
                                                displayFormat="dd/MM/yyyy"
                                                valueFormat="dd/MM/yyyy"
                                                change="_onChangeDateRange" />
                                        </fb:control>
                                    </fb:FilterItem>

                                <!-- FACTURA (MultiComboBox) -->
                                <fb:FilterItem
                                    name="G"
                                    label="{i18n>txtFactura}">
                                    <fb:control>
                                        <MultiComboBox
                                            id="mcbFactura"
                                            width="100%"
                                            enabled="false"
                                            items="{
                                                path: 'oModelProyect>/oFacturaLista'
                                            }"
                                            selectionFinish=".onFacturaSelectionFinish"
                                            selectedKeys="{oModelProyect>/Main/filter/fFactura}">
                                            <core:Item
                                                key="{oModelProyect>NRO_FACTURA}"
                                                text="{oModelProyect>NRO_FACTURA}" />
                                        </MultiComboBox>
                                    </fb:control>
                                </fb:FilterItem>

                                <!-- FECHA DE EMISIÓN (OPCIONAL) -->
                                <fb:FilterItem
                                    name="H"
                                    label="Fecha Emisión">
                                    <fb:control>
                                        <DatePicker
                                            id="dtpFechFact"
                                            displayFormat="dd-MM-yyyy"
                                            enabled="true"
                                            width="100%"
                                            value="{oModelProyect>/Main/filter/fFechaEmision}" />

                                    </fb:control>
                                </fb:FilterItem>

                            </fb:filterItems>

                        </fb:FilterBar>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>

            <f:content>
                <VBox>
                     <VBox id="vbTableMain"/>
                </VBox>
            </f:content>
        </f:DynamicPage>
</mvc:View>