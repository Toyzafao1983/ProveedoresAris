<mvc:View controllerName="com.aris.proveedores.facturaexterior.pe.controller.Detail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:form="sap.ui.layout.form"
    xmlns:l="sap.ui.layout"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">
    <Shell>
        <f:DynamicPage headerExpanded="true" showFooter="true">
            <f:title>
                <f:DynamicPageTitle>
                    <f:heading>
                        <Title level="H1" text="
                        {= ${oModelUser>/bAdmin} ? ${i18n>title} +'-'+ ${oModelUser>/sNameComp} : ${i18n>title}  }
                        " wrapping="true" />
                    </f:heading>
                    <f:navigationActions>
                        <Button text="{i18n>textbtnBackTo}" icon="sap-icon://nav-back" press="_onPressNavButtonDetail"/>
                    </f:navigationActions>
                    <f:actions>
                        <ToolbarSpacer/>
                        <Button text="{i18n>btnEdit}" press="_onEnableCabecera" type="Emphasized" icon="sap-icon://edit" visible="{= ${oModelProyect>/appContext/bEditMode} ? false : !${oModelProyect>/oCabecera/bLockedByStatus} }"/>
                        <Button text="{i18n>saveText}" press="_onPressEnviarFacturaExterior" type="Transparent" icon="sap-icon://save" visible="{= !${oModelProyect>/oCabecera/bLockedByStatus} }" />
                        <Button text="{i18n>btnDelete}" press="_onPressEliminarSolicitudFacturacion" type="Transparent" icon="sap-icon://delete" visible="{= !${oModelProyect>/oCabecera/bLockedByStatus} }"/>
                    </f:actions>
                </f:DynamicPageTitle>
            </f:title>
            <f:header>
                <f:DynamicPageHeader>
                    <f:content>
                        <VBox >
                            <form:SimpleForm id="sfcCabecera"
                                editable="true"
                                layout="ResponsiveGridLayout"
                                labelSpanXL="4"
                                labelSpanL="4"
                                labelSpanM="12"
                                labelSpanS="12"
                                adjustLabelSpan="false"
                                emptySpanXL="0"
                                emptySpanL="0"
                                emptySpanM="0"
                                emptySpanS="0"
                                columnsXL="2"
                                columnsL="2"
                                columnsM="1"
                                singleContainerFullSize="false" >
                                <form:content>
                                    <core:Title text="Aris Industrial S.A." />
                                    <Label text="{i18n>sDetalleFechaFactura}" />
                                    <DatePicker displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" editable="{oModelProyect>/oCabecera/bFormEditable}"
                                        value="{oModelProyect>/oCabecera/sFormFechaFactura}"/>

                                    <Label text="{i18n>sDetalleClaseDocumento}" />
                                   <ComboBox
                                        id="cbClaseDocumento"
                                        editable="false"
                                        showSecondaryValues="true"
                                        filterSecondaryValues="true"
                                        selectedKey="{oModelProyect>/oCabecera/sFormClaseDocumento}"
                                        items="{
                                            path:'oModelData>/oClaseDocumento', templateShareable:false
                                        }"
                                        change="ChangeSelectedDetalleHeaderTo"
                                        custom:custom="sFormClaseDocumento/DocumentClassDescription" >
                                        <core:ListItem
                                            key="{oModelData>DocumentClass}"
                                            text="{= ${oModelData>DocumentClassDescriptionI18n} || ${oModelData>DocumentClassDescription} }"
                                            additionalText="{oModelData>DocumentClass}" />
                                    </ComboBox>
                                    <!-- <Input value="{oModelProyect>/oCabecera/sFormClaseDocumento}" liveChange="liveChangeFormatInteger" enabled="{oModelProyect>/oCabecera/bFormEditable}"/> -->

                                    <Label text="{i18n>sDetalleNumFac}" />
                                    <Input
                                        id="inpNumeroFactura"
                                        value="{oModelProyect>/oCabecera/sFormNumeroFactura}"
                                        liveChange="liveChangeNumeroFacturaMax25"
                                        maxLength="25"
                                        editable="{oModelProyect>/oCabecera/bFormEditable}"
                                    />
                                                                        
                                    <Label text="{i18n>sDetalleImportFactura}" />
                                    <Input value="{oModelProyect>/sTotal}" liveChange="liveChangeFormatFloat" editable="false"/>

                                    <Label text="{i18n>sDetalleFechaBase}" />
                                    <DatePicker
                                        id="dpFechaBase"
                                        displayFormat="dd/MM/yyyy"
                                        valueFormat="dd/MM/yyyy"
                                        editable="{oModelProyect>/oCabecera/bFormEditable}"
                                        value="{oModelProyect>/oCabecera/sFormFechaBase}" />

                                    <core:Title text="" />
                                    <Label text="{i18n>sDetalleFechaCont}" />
                                    <DatePicker displayFormat="dd/MM/yyyy" valueFormat="dd/MM/yyyy" editable="false"
                                        value="{oModelProyect>/oCabecera/sFormFechaContabilizacion}"/>

                                    <Label text="{i18n>sDetalleMoneda}" />
                                    <Text text="{oModelProyect>/oCabecera/sFormMoneda}" />

                                    <Label text="{i18n>sDetalleCondPago}" />
                                    <Input value="{oModelProyect>/oCabecera/sFormCondicionPagoOrderDescrip}" editable="false"/>

                                    <Label text="{i18n>sDetalleEstReg}" />
                                    <Text text="{oModelProyect>/oCabecera/sFormEstadoRegistro}" />
                                </form:content>
                            </form:SimpleForm>
                        </VBox>
                    </f:content>
                </f:DynamicPageHeader>
            </f:header>
            <f:content>
                <core:Fragment fragmentName="com.aris.proveedores.facturaexterior.pe.view.fragments.TableOrder" type="XML"/>
            </f:content>
            <f:footer>
                <OverflowToolbar>
                    <ToolbarSpacer/>
                    <Button type="Accept" text="{i18n>btnGenerateInvoice}" press="_onPressGenerarFactura"
                    enabled="{= !( ${oModelProyect>/oCabecera/sEstadoCodigo} === '00'|| ${oModelProyect>/oCabecera/sEstadoCodigo} === '02' || ${oModelProyect>/oCabecera/sEstadoCodigo} === '03' || ${oModelProyect>/oCabecera/sEstadoCodigo} === '04') }"/>
                    <Button type="Accept" text="{i18n>btnReviewedComex}" press="_onPressGenerarComex" enabled="{= ${oModelProyect>/oCabecera/sEstadoCodigo} === '02' }" visible= "{= ${oModelUser>/bIsIntComex}}"/>
                </OverflowToolbar>
            </f:footer>
        </f:DynamicPage>
        
    </Shell>
</mvc:View>