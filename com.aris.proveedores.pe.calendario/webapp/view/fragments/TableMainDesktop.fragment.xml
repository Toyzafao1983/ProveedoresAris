<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core" 
    xmlns:l="sap.ui.layout">

    <IconTabBar id="itbAnios" items="{oModelData>/Anios}">
        <items>
            <IconTabFilter text="{oModelData>Anio}">
                <FlexBox wrap="Wrap" justifyContent="Start" alignItems="Start" items="{oModelData>Meses}">
                    <VBox class="mesCard">
                        
                        <!-- 🔹 El nombre del mes se resuelve con formatter y depende también de /sIdioma -->
                        <Label 
                            text="{
                                parts: ['oModelData>MesNum', 'oModelProyect>/sIdioma'],
                                formatter: '.formatter.formatMonth'
                            }"
                            class="mesHeader"
                            width="100%"/>
                        
                        <!-- Fechas del mes -->
                        <l:Grid defaultSpan="L6 M6 S6" class="mesBody" content="{oModelData>Fechas}">
                            <Text text="{oModelData>Day}" class="fechaItem"/>
                        </l:Grid>

                    </VBox>
                </FlexBox>
            </IconTabFilter>
        </items>
    </IconTabBar>

</core:FragmentDefinition>