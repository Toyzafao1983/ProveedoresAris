<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form" xmlns:mdc="sap.ui.mdc">
    <ScrollContainer width="100%" height="50%">
        <Table id="tblMain" items="{oModelProyect>/oReporte}"  mode="None" growingThreshold="20" autoPopinMode="false" growing="true" sticky="ColumnHeaders,HeaderToolbar" popinLayout="GridSmall"  updateFinished="_onUpdateFinished" >
            <headerToolbar>
                <Toolbar>
                <ToolbarSpacer/>
                    <Button id="btnExpRespaldo" text="{i18n>textbtnExpRespaldo}" type="Accept" icon="sap-icon://excel-attachment" press="_onPressExportRespaldo"/>
                </Toolbar>
            </headerToolbar>
            <columns>
                <Column width="200px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false" visible="{= ${oModelUser>/bAdmin}}">
                    <header>
                        <Text text="{i18n>titleProveedor}" width="auto" />
                    </header>
                </Column>
                
                <Column width="110px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleRUC}" width="auto" />
                    </header>
                </Column>
                <Column width="100px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleCodSap}" width="auto" />
                    </header>
                </Column>
                <Column width="200px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleAdress}" width="auto" />
                    </header>
                </Column>
                <Column width="200px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleEmail}" width="auto" />
                    </header>
                </Column>
                <Column width="200px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleHowManyBanks}" width="auto" />
                    </header>
                </Column>
                <Column width="200px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleContactPerson}" width="auto" />
                    </header>
                </Column>
                <Column width="100px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleMobilePhone}" width="auto" />
                    </header>
                </Column>
                <Column width="100px" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                    <header>
                        <Text text="{i18n>titleButtonDetail}" width="auto" />
                    </header>
                </Column>
            </columns>
        <items>
                <ColumnListItem type="Inactive">
                    <cells>
                        <Text text="{path:'oModelProyect>SupplierName'}" visible="{= ${oModelUser>/bAdmin}}"/>
                        <Text text="{path:'oModelProyect>TaxID'}"/>
                        <Text text="{path:'oModelProyect>SupplierCode'}"/>
                        <Text text="{path:'oModelProyect>to_Address/results/0/Street'}  {path:'oModelProyect>to_Address/results/0/City'}"/>
                        <Text text="{path:'oModelProyect>to_Emails/results/0/Email'}"/>
                        <Text text="{path:'oModelProyect>to_BankAccounts/results/0/BankName'} - {path:'oModelProyect>to_BankAccounts/results/0/BankAccount'}"/>
                        <Text text="{path:'oModelProyect>to_Contacts/results/0/ContactPerson'}"/>
                        <Text text="{path:'oModelProyect>to_Contacts/results/0/PhoneNumber'}"/>
                        <Button text="{i18n>titleButtonDetail}" press="_onPressNavigateDetail"/>
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </ScrollContainer>
</core:FragmentDefinition>