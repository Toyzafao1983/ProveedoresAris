<mvc:View controllerName="com.aris.proveedores.pe.pedidocompra.controller.View"
   xmlns:mvc="sap.ui.core.mvc"
    xmlns:core="sap.ui.core"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:fb="sap.ui.comp.filterbar"
    xmlns:svm="sap.ui.comp.smartvariants"
    xmlns:custom="http://schemas.sap.com/sapui5/extension/sap.ui.core.CustomData/1">


        <f:DynamicPage headerExpanded="true">
                <f:title>
                    <f:DynamicPageTitle>
                       <f:heading>
                            <Title
                                level="H1"
                                text="{i18n>title}"
                                wrapping="true"/>
                        </f:heading>
                        <f:actions>
                            <Button text="{i18n>textHome}" press="_onbtnHome" type="Back" icon="sap-icon://home" tooltip="{i18n>tooltipbtnHome}"/>
                            <MenuButton text="{i18n>titleButtonLanguaje}">
                                    <menu>
                                        <Menu itemSelected="onMenuAction">
                                            <MenuItem text="{i18n>titleButtonLanguajeES}" press="onLanguageEsp"/>
                                            <MenuItem text="{i18n>titleButtonLanguajeEN}" press="onLanguageEng"/>
                                        </Menu>
                                    </menu>
                                </MenuButton>

                        </f:actions>
                    </f:DynamicPageTitle>
                </f:title>
                <f:header>
                    <f:DynamicPageHeader>
                        <f:content>
                            <fb:FilterBar id="idFilterBar" filterContainerWidth="11rem" reset="onReset" search="_onPressExecute" showFilterConfiguration="true"
                                 showClearOnFB="true" showGoOnFB="true" clear="_onPressClear" useToolbar="true" persistencyKey="" >
                                <fb:filterItems>
                                
                                    <fb:FilterItem name="A" label="{i18n>txtProveedor}" visible="{= ${oModelUser>/bRol}}">
                                        <fb:control >
                                            <MultiInput
                                                id="miProv"
                                                width="300px"
                                                showClearIcon="true"
                                                showSuggestion="true"
                                                showValueHelp="false"
                                                suggest="onChangeProv"
                                                visible="{= ${oModelUser>/bAdmin}}"
                                                suggestionItems="{
                                                    path: 'oModelData>/oFiltroProv'
                                                }"
                                               
                                                custom:custom="cbSupplier/Bpname">
                                                <suggestionItems>
                                                    <core:Item key="{oModelData>Bpname}" text="{oModelData>Display}" />
                                                </suggestionItems>
                                            </MultiInput>
                                        </fb:control>
                                    </fb:FilterItem>
                                    
                                    <fb:FilterItem name="B" label="{i18n>txtCodProveedor}" visible="{= ${oModelUser>/bRol}}">
                                        <fb:control>
                                            <MultiInput
                                                id="miCodProv"
                                                width="300px"
                                                showClearIcon="true"
                                                showSuggestion="true"
                                                showValueHelp="false"
                                                suggest="onChangeRuc"
                                                suggestionItems="{
                                                    path: 'oModelData>/oFiltroRuc'
                                                }"
                                                custom:custom="cbRuc/Ruc">
                                                <suggestionItems>
                                                    <core:Item key="{oModelData>Ruc}" text="{oModelData>Display}" />
                                                </suggestionItems>
                                            </MultiInput>
                                            
                                        </fb:control>
                                    </fb:FilterItem>

                                    <fb:FilterItem name="C" label="{i18n>txtPedidoCompra}">
                                        <fb:control >
                                            <MultiInput
                                                id="miPedComp"
                                                width="300px"
                                                showClearIcon="true"
                                                showSuggestion="true"
                                                showValueHelp="false"
                                                suggest="onChangeNroPedComp"
                                                suggestionItems="{
                                                    path: 'oModelData>/oFiltroNroPedComp'
                                                }"
                                               
                                                custom:custom="cbPedComp/Ebeln">
                                                <suggestionItems>
                                                    <core:Item key="{oModelData>Ebeln}" text="{oModelData>Display}" />
                                                </suggestionItems>
                                            </MultiInput>
                                        </fb:control>
                                    </fb:FilterItem>
                                    
                                    <fb:FilterItem name="D" label="{i18n>txtFechPedido}">
                                        <fb:control>
                                            <DateRangeSelection id="dprFilterInitFechPedido" width="250px" displayFormat="dd/MM/yyyy" visible="true" valueFormat="dd/MM/yyyy" change="_onChangeDateRange"  />
                                        </fb:control>
                                    </fb:FilterItem>

                                    <fb:FilterItem name="E" label="{i18n>txtEstado}">
                                        <fb:control>
                                             <MultiComboBox
                                                id="mcEstado"
                                                width="300px"
                                                showClearIcon="true"
                                                items="{
                                                    path: 'oModelData>/oFiltroState'
                                                }">
                                                <core:Item key="{oModelData>StateKey}" text="{oModelData>Display}" />
                                            </MultiComboBox>

                                        </fb:control>
                                    </fb:FilterItem>
                                    
                                    <fb:FilterItem name="F" label="{i18n>txtFactuacion}">
                                        <fb:control>
                                            <MultiComboBox
                                                id="mcFacturacion"
                                                width="300px"
                                                showClearIcon="true"
                                                items="{
                                                    path: 'oModelData>/oFiltroFacturacion'
                                                }">
                                                <core:Item key="{oModelData>StateKey}" text="{oModelData>Display}" />
                                            </MultiComboBox>
                                        </fb:control>
                                    </fb:FilterItem>
                                    <fb:FilterItem name="G" label="{i18n>txtCondPago}">
                                        <fb:control >
                                             <MultiComboBox
                                                id="mcCondPago"
                                                width="300px"
                                                showClearIcon="true"
                                                items="{
                                                    path: 'oModelData>/oFiltroCondPago'
                                                }">
                                                <core:Item key="{oModelData>Conpag}" text="{oModelData>Display}" />
                                            </MultiComboBox>
                                        </fb:control>
                                    </fb:FilterItem>
                                    <fb:FilterItem name="H" label="{i18n>txtIncoterm}">
                                        <fb:control >
                                            <MultiComboBox
                                                id="mcIntercom"
                                                width="300px"
                                                showClearIcon="true"
                                                items="{
                                                    path: 'oModelData>/oFiltroIntercom'
                                                }">
                                                <core:Item key="{oModelData>StateKey}" text="{oModelData>Display}" />
                                            </MultiComboBox>
                                        </fb:control>
                                    </fb:FilterItem>
                                    <fb:FilterItem name="I" label="{i18n>txtModalidad}">
                                        <fb:control >
                                            <MultiComboBox
                                                id="mcModalidad"
                                                width="300px"
                                                showClearIcon="true"
                                                items="{
                                                    path: 'oModelData>/oFiltroModalidad'
                                                }">
                                                <core:Item key="{oModelData>StateKey}" text="{oModelData>Display}" />
                                            </MultiComboBox>
                                        </fb:control>
                                    </fb:FilterItem>
                                    <fb:FilterItem name="J" label="{i18n>txtFechEntrega}">
                                        <fb:control >
                                            <DateRangeSelection id="dprFilterInitFechentrega" width="250px" displayFormat="dd/MM/yyyy" visible="true" 
                            valueFormat="dd/MM/yyyy" change="_onChangeDateRange" />
                                        </fb:control>
                                    </fb:FilterItem>

                                    
                                </fb:filterItems>
                            </fb:FilterBar>
                        </f:content>
                    </f:DynamicPageHeader>
                </f:header>
                
                <f:content>
               
                    <VBox >
                        <VBox >
                         <VBox id="vbTableMain">
                        </VBox>
                        </VBox>
                    </VBox>
                
                </f:content>
           
            </f:DynamicPage>
    
</mvc:View>