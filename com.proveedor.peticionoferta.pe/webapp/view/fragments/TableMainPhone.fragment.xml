<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout" xmlns:f="sap.ui.layout.form">
    <Table items="{oModelProyect>/oReporte}"  mode="MultiSelect" growingThreshold="20"  >
        <headerToolbar>
                      <Toolbar>
    <ToolbarSpacer/>

    <!-- Guardar Oferta -->
    <Button 
        text="{i18n>btnSavePet}" 
        press="onSaveOffer" 
        icon="sap-icon://save" 
        type="Success" 
        tooltip="{i18n>btnSavePet}" />

    <!-- Editar Oferta -->
    <Button 
        text="{i18n>btnEditPet}" 
        press="_onPressExectudEdit" 
        icon="sap-icon://edit" 
        type="Emphasized" 
        tooltip="{i18n>btnEditPet}" />

    <!-- Bloquear Oferta -->
    <Button 
        text="{i18n>btnBlocPet}" 
        press="onBlockOffer" 
        icon="sap-icon://locked" 
        type="Negative" 
        tooltip="{i18n>btnBlocPet}" />
</Toolbar>
        </headerToolbar>
        <columns>

           <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtProbInit}" width="auto" />
                </header>
            </Column>

            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtNumberPet}" width="auto" />
                </header>
            </Column>
            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtFechPedido}" width="auto" />
                </header>
            </Column>
            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtFechOfert}" width="auto" />
                </header>
            </Column>
            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtCondPago}" width="auto" />
                </header>
            </Column>
            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtCondInit}" width="auto" />
                </header>
            </Column>
            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtEstado}" width="auto" />
                </header>
            </Column>

            <Column width="auto" hAlign="Center" vAlign="Middle" minScreenWidth="Tablet" demandPopin="true" popinDisplay="Inline" mergeDuplicates="false">
                <header>
                    <Text text="{i18n>txtView}" width="auto" />
                </header>
            </Column>
        </columns>
       <items>
            <ColumnListItem type="Inactive">
                <cells>
                    <Text text="{path:'oModelProyect>txt0'}"/>
                    <Text text="{path:'oModelProyect>txt1'}"/>
                    <Text text="{path:'oModelProyect>txt2'}"/>
                    <Text text="{path:'oModelProyect>priceUnit'}"/>
                    <Text text="{path:'oModelProyect>txt3'}"/>
                    <Text text="{path:'oModelProyect>txt4'}"/>
                    <Text text="{path:'oModelProyect>txt5'}"/>
                    <Button text="{i18n>titleButtonMas}" press="_onPressNavigateDetail"/>
                </cells>
            </ColumnListItem>
        </items>
    </Table>
</core:FragmentDefinition>